{
  "name": "@causet/sdk-next",
  "version": "0.2.0",
  "description": "Next.js helpers and React hooks for Causet",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Causet-Inc/causet-sdks.git",
    "directory": "packages/next"
  },
  "bugs": {
    "url": "https://github.com/Causet-Inc/causet-sdks/issues"
  },
  "homepage": "https://github.com/Causet-Inc/causet-sdks/tree/main/packages/next#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@causet/sdk-core": "0.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
